// ============================================================
// schema.prisma — F&B SaaS Multi-Tenant Platform
// Database: MySQL
// ORM: Prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum PlanType {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  CASHIER
  KITCHEN
  WAITER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum OrderSource {
  DINE_IN
  QR_ORDER
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum PaymentMethodType {
  CASH
  CARD
  QR_CODE
  TRANSFER
}

enum InventoryReason {
  PURCHASE
  SALE
  ADJUSTMENT
  WASTE
  TRANSFER
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ============================================================
// MULTI-TENANT FOUNDATION
// ============================================================

model Tenant {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  logoUrl     String?
  planType    PlanType  @default(FREE)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  plans           TenantPlan[]
  branches        Branch[]
  users           User[]
  categories      Category[]
  products        Product[]
  paymentMethods  PaymentMethod[]
  discounts       Discount[]

  @@map("tenants")
}

model TenantPlan {
  id           String    @id @default(uuid())
  tenantId     String
  planName     String
  maxBranches  Int       @default(1)
  maxUsers     Int       @default(5)
  maxProducts  Int       @default(100)
  startsAt     DateTime  @default(now())
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_plans")
}

// ============================================================
// BRANCH & STAFF
// ============================================================

model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  tables          Table[]
  orders          Order[]
  inventoryLogs   InventoryLog[]
  shiftReports    ShiftReport[]
  reservations    Reservation[]
  inventoryItems  InventoryItem[]

  @@map("branches")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  branchId     String?
  name         String
  email        String    @unique
  passwordHash String
  phone        String?
  role         UserRole  @default(CASHIER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch?  @relation(fields: [branchId], references: [id])
  orders  Order[]

  @@map("users")
}

// ============================================================
// TABLE MANAGEMENT
// ============================================================

model Table {
  id        String      @id @default(uuid())
  branchId  String
  name      String
  capacity  Int         @default(4)
  status    TableStatus @default(AVAILABLE)
  qrCode    String?     @unique
  floorMap  String?     @db.Text
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  orders        Order[]
  reservations  Reservation[]

  @@map("tables")
}

// ============================================================
// MENU
// ============================================================

model Category {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  imageUrl     String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@map("categories")
}

model Product {
  id            String   @id @default(uuid())
  tenantId      String
  categoryId    String?
  name          String
  description   String?  @db.Text
  basePrice     Int
  imageUrl      String?
  stockQuantity Int      @default(0)
  isAvailable   Boolean  @default(true)
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category      Category?            @relation(fields: [categoryId], references: [id])
  variants      ProductVariant[]
  orderItems    OrderItem[]
  inventoryLogs InventoryLog[]
  ingredients   ProductIngredient[]

  @@map("products")
}

model ProductVariant {
  id            String   @id @default(uuid())
  productId     String
  name          String
  priceModifier Int      @default(0)
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())

  product      Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
  ingredients  ProductIngredient[]

  @@map("product_variants")
}

// ============================================================
// PRODUCT INGREDIENTS (liên kết món ↔ nguyên liệu, hỗ trợ theo size)
// ============================================================

model ProductIngredient {
  id        String  @id @default(uuid())
  productId String
  itemId    String
  variantId String?  // null = áp dụng cho tất cả size
  quantity  Float

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  item    InventoryItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([productId, itemId, variantId])
  @@map("product_ingredients")
}

// ============================================================
// ORDER FLOW
// ============================================================

model Order {
  id            String      @id @default(uuid())
  branchId      String
  tableId       String?
  cashierId     String?
  discountId    String?
  orderCode     String      @unique
  source        OrderSource @default(DINE_IN)
  status        OrderStatus @default(PENDING)
  paymentMethod String?
  note          String?     @db.Text
  subtotal      Int
  discount      Int         @default(0)
  tax           Int         @default(0)
  total         Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  completedAt   DateTime?

  branch    Branch      @relation(fields: [branchId], references: [id])
  table     Table?      @relation(fields: [tableId], references: [id])
  cashier   User?       @relation(fields: [cashierId], references: [id])
  discountR Discount?   @relation(fields: [discountId], references: [id])
  items     OrderItem[]
  payment   Payment?

  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  productId  String
  variantId  String?
  quantity   Int
  unitPrice  Int
  subtotal   Int
  note       String?
  createdAt  DateTime @default(now())

  order    Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product  Product         @relation(fields: [productId], references: [id])
  variant  ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// ============================================================
// PAYMENT
// ============================================================

model PaymentMethod {
  id        String            @id @default(uuid())
  tenantId  String
  name      String
  type      PaymentMethodType
  config    Json?
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments  Payment[]

  @@map("payment_methods")
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique
  methodId      String
  amount        Int
  status        PaymentStatus @default(PENDING)
  referenceCode String?
  metadata      Json?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order   Order         @relation(fields: [orderId], references: [id])
  method  PaymentMethod @relation(fields: [methodId], references: [id])

  @@map("payments")
}

// ============================================================
// DISCOUNT / PROMOTION
// ============================================================

model Discount {
  id            String       @id @default(uuid())
  tenantId      String
  code          String
  description   String?
  type          DiscountType
  value         Int
  minOrderValue Int?
  maxUses       Int?
  usedCount     Int          @default(0)
  isActive      Boolean      @default(true)
  startsAt      DateTime?
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@unique([tenantId, code])
  @@map("discounts")
}

// ============================================================
// INVENTORY LOG (cũ — gắn với Product)
// ============================================================

model InventoryLog {
  id             String          @id @default(uuid())
  productId      String
  branchId       String
  quantityChange Int
  quantityBefore Int
  quantityAfter  Int
  reason         InventoryReason
  note           String?
  createdBy      String?
  createdAt      DateTime        @default(now())

  product  Product  @relation(fields: [productId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])

  @@map("inventory_logs")
}

// ============================================================
// SHIFT REPORT
// ============================================================

model ShiftReport {
  id            String    @id @default(uuid())
  branchId      String
  openedBy      String
  closedBy      String?
  openingCash   Int
  closingCash   Int?
  totalRevenue  Int?
  totalOrders   Int?
  note          String?   @db.Text
  openedAt      DateTime  @default(now())
  closedAt      DateTime?

  branch  Branch  @relation(fields: [branchId], references: [id])

  @@map("shift_reports")
}

// ============================================================
// RESERVATION
// ============================================================

model Reservation {
  id            String            @id @default(uuid())
  branchId      String
  tableId       String?
  customerName  String
  customerPhone String
  partySize     Int
  reservedAt    DateTime
  note          String?           @db.Text
  status        ReservationStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  branch  Branch  @relation(fields: [branchId], references: [id])
  table   Table?  @relation(fields: [tableId], references: [id])

  @@map("reservations")
}

// ============================================================
// INVENTORY ITEM (mới — quản lý nguyên liệu độc lập)
// ============================================================

model InventoryItem {
  id          String   @id @default(uuid())
  branchId    String
  name        String
  unit        String   @default("kg")
  quantity    Float    @default(0)
  minQuantity Float    @default(10)
  costPrice   Float    @default(0)
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch       Branch              @relation(fields: [branchId], references: [id])
  logs         InventoryItemLog[]
  ingredients  ProductIngredient[]

  @@map("inventory_items")
}

model InventoryItemLog {
  id          String   @id @default(uuid())
  itemId      String
  type        String
  quantity    Float
  note        String?
  createdBy   String?
  createdAt   DateTime @default(now())

  item  InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("inventory_item_logs")
}